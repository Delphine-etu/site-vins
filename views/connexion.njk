{% extends "layout.njk" %}

{% block title %}Se connecter{% endblock %}

{% block content %}
  <h2 style="text-align: center">Se connecter</h2>
  <p>Si vous possédez déjà un compte, veuillez vous identifier ci-dessous.</p>
   <form action="/formco" method="get">
    <fieldset>
        <legend>Connexion à votre compte</legend>
        <div style="display:flex; flex-wrap:wrap, justify-content:flex-start; gap:5px; margin-top:7px">
          <label for="email" style="width:93px">E-mail :</label>
          <input id="email" name="email" type="email" placeholder="votremail@exemple.com" required>
        </div>
        
        <div style="display:flex; flex-wrap:wrap, justify-content:flex-start; gap:5px; margin-top:7px">
          <label for="password" style="width:93px">Mot de passe :</label>
          <input id="password" name="password" type="password" required minlength="6" placeholder="Min. 6 caractères">
        </div>
      </fieldset>
    
      <div class="form-actions" style="margin-top:5px">
        <button type="submit">Se connecter</button>
        <button type="reset">Réinitialiser</button>
      </div>
    </form>
{% endblock %}
